{
    "name": "divi-to-elementor/migration-plugin",
    "description": "DiviToElementor — WordPress plugin for migrating Divi content to Elementor",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "brain/monkey": "^2.6",
        "php-stubs/wordpress-stubs": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "DiviToElementor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DiviToElementor\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
